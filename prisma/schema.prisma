generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  firstname     String?
  surname       String?
  email         String?      @unique
  emailVerified DateTime?    @map("email_verified")
  image         String?
  role          Role         @default(OWNER)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  name          String?
  middleName    String?      @map("middle_name")
  password      String?
  phoneNumber   String?      @unique @map("phone_number")
  accounts      Account[]
  batches       Batch[]
  feedingLogs   FeedingLog[]
  memberships   FarmMember[]
  farms         Farm[]
  sessions      Session[]
  expenses      Expense[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Farm {
  id              Int             @id @default(autoincrement())
  name            String
  location        String?
  capacity        Int
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  userId          String          @default("user_placeholder")
  members         FarmMember[]
  user            User            @relation(fields: [userId], references: [id])
  houses          House[]
  invitations     Invitation[]
  batches         Batch[]
  inventory       Inventory[]
  feedingLogs     FeedingLog[]
  healthRecords   HealthRecord[]
  eggProduction   EggProduction[]
  mortality       Mortality[]
  weightRecords   WeightRecord[]
  sales           Sale[]
  saleItems       SaleItem[]
  expenses        Expense[]
  vaccinations    VaccinationSchedule[]
  medications     MedicationSchedule[]
  settings        FarmSettings?

  @@index([userId])
  @@map("farms")
}

model House {
  id                 Int      @id @default(autoincrement())
  farmId             Int
  name               String
  capacity           Int
  currentTemperature Decimal? @db.Decimal(5, 2)
  currentHumidity    Decimal? @db.Decimal(5, 2)
  userId             String   @default("user_placeholder")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  batches            Batch[]
  farm               Farm     @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("houses")
}

model Batch {
  id               Int             @id @default(autoincrement())
  status           String          @default("active")
  arrivalDate      DateTime
  breedType        String
  createdAt        DateTime        @default(now())
  currentCount     Int
  houseId          Int
  farmId           Int             @default(1)
  initialCount     Int
  updatedAt        DateTime        @updatedAt
  userId           String          @default("user_placeholder")
  house            House           @relation(fields: [houseId], references: [id])
  farm             Farm            @relation(fields: [farmId], references: [id])
  user             User            @relation(fields: [userId], references: [id])
  feedingLogs      FeedingLog[]
  eggProduction    EggProduction[]
  healthRecords    HealthRecord[]
  mortalityRecords Mortality[]
  weightRecords    WeightRecord[]
  vaccinations     VaccinationSchedule[]
  medications      MedicationSchedule[]

  @@index([userId])
  @@index([farmId])
  @@map("batches")
}

model Inventory {
  id           Int          @id @default(autoincrement())
  itemName     String
  stockLevel   Decimal      @db.Decimal(10, 2)
  reorderLevel Decimal?     @default(500.00) @db.Decimal(10, 2)
  unit         String
  category     String?
  userId       String       @default("user_placeholder")
  farmId       Int          @default(1)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  feedingLogs  FeedingLog[]
  farm         Farm         @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("inventory")
}

model FeedingLog {
  id             Int        @id @default(autoincrement())
  batchId        Int?       @map("batch_id")
  feedTypeId     Int?       @map("feed_type_id")
  amountConsumed Decimal    @map("amount_consumed") @db.Decimal(10, 2)
  logDate        DateTime   @default(now()) @map("log_date")
  userId         String?    @map("user_id")
  farmId         Int        @default(1)
  batch          Batch?     @relation(fields: [batchId], references: [id])
  inventory      Inventory? @relation(fields: [feedTypeId], references: [id])
  user           User?      @relation(fields: [userId], references: [id])
  farm           Farm       @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("daily_feeding_logs")
}

model HealthRecord {
  id          Int      @id @default(autoincrement())
  batchId     Int?     @map("batch_id")
  recordType  String?  @map("record_type") @db.VarChar(50)
  description String?
  recordDate  DateTime @default(now()) @map("record_date") @db.Date
  farmId      Int      @default(1)
  batch       Batch?   @relation(fields: [batchId], references: [id])
  farm        Farm     @relation(fields: [farmId], references: [id])

  @@index([farmId])
  @@map("health_records")
}

model EggProduction {
  id            Int      @id @default(autoincrement())
  batchId       Int
  eggsCollected Int
  damagedEggs   Int      @default(0)
  crackedEggs   Int      @default(0)
  logDate       DateTime
  userId        String   @default("user_placeholder")
  farmId        Int      @default(1)
  createdAt     DateTime @default(now())
  batch         Batch    @relation(fields: [batchId], references: [id])
  farm          Farm     @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("egg_production")
}

model Mortality {
  id          Int      @id @default(autoincrement())
  batchId     Int
  count       Int
  reason      String?
  category    String?
  subCategory String?  @map("sub_category")
  logDate     DateTime
  userId      String   @default("user_placeholder")
  farmId      Int      @default(1)
  createdAt   DateTime @default(now())
  batch       Batch    @relation(fields: [batchId], references: [id])
  farm        Farm     @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("mortality")
}

model WeightRecord {
  id            Int      @id @default(autoincrement())
  batchId       Int
  averageWeight Decimal  @db.Decimal(10, 3)
  logDate       DateTime
  userId        String   @default("user_placeholder")
  farmId        Int      @default(1)
  createdAt     DateTime @default(now())
  batch         Batch    @relation(fields: [batchId], references: [id])
  farm          Farm     @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("weight_records")
}

model Sale {
  id           Int        @id @default(autoincrement())
  customerName String?
  totalAmount  Decimal    @db.Decimal(10, 2)
  saleDate     DateTime   @default(now())
  status       String     @default("completed")
  userId       String     @default("user_placeholder")
  farmId       Int        @default(1)
  createdAt    DateTime   @default(now())
  items        SaleItem[]
  farm         Farm       @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("sales")
}

model SaleItem {
  id          Int     @id @default(autoincrement())
  saleId      Int
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)
  farmId      Int     @default(1)
  sale        Sale    @relation(fields: [saleId], references: [id])
  farm        Farm    @relation(fields: [farmId], references: [id])

  @@index([farmId])
  @@map("sale_items")
}

model FarmMember {
  id        Int      @id @default(autoincrement())
  farmId    Int
  userId    String
  role      Role     @default(WORKER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  farm      Farm     @relation(fields: [farmId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([farmId, userId])
  @@map("farm_members")
}

model Invitation {
  id          Int      @id @default(autoincrement())
  email       String?
  phoneNumber String?  @unique @map("phone_number")
  farmId      Int      @map("farm_id")
  role        Role     @default(WORKER)
  status      String   @default("PENDING")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  farm        Farm     @relation(fields: [farmId], references: [id])

  @@unique([email, farmId])
  @@index([farmId])
  @@map("invitations")
}

enum Role {
  OWNER
  MANAGER
  WORKER
}

model VaccinationSchedule {
  id            Int      @id @default(autoincrement())
  batchId       Int
  vaccineName   String
  scheduledDate DateTime
  status        String   @default("PENDING") // PENDING, COMPLETED, SKIPPED
  notes         String?
  farmId        Int      @default(1)
  farm          Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  batch         Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([farmId])
  @@map("vaccination_schedules")
}

model MedicationSchedule {
  id             Int      @id @default(autoincrement())
  batchId        Int
  medicationName String
  scheduledDate  DateTime
  status         String   @default("PENDING") // PENDING, COMPLETED, SKIPPED
  notes          String?
  farmId         Int      @default(1)
  farm           Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  batch          Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([farmId])
  @@map("medication_schedules")
}

model FarmSettings {
  id                     Int      @id @default(autoincrement())
  farmId                 Int      @unique
  eggRecordReminderTime  String?  @default("18:00") // 24h format
  feedRecordReminderTime String?  @default("18:00")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  farm                   Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@map("farm_settings")
}

model AuditLog {
  id            Int      @id @default(autoincrement())
  tableName     String   @map("table_name")
  recordId      Int      @map("record_id")
  attributeName String   @map("attribute_name")
  oldValue      String?  @map("old_value")
  newValue      String?  @map("new_value")
  reason        String?
  userId        String   @map("user_id")
  farmId        Int      @map("farm_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([farmId])
  @@index([userId])
  @@map("audit_logs")
}

model Expense {
  id          Int      @id @default(autoincrement())
  farmId      Int
  userId      String   @map("user_id")
  amount      Decimal  @db.Decimal(10, 2)
  category    ExpenseCategory
  description String?
  expenseDate DateTime @default(now()) @map("expense_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  farm        Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@index([farmId])
  @@index([userId])
  @@map("expenses")
}

enum ExpenseCategory {
  FEED
  MEDICATION
  EQUIPMENT
  UTILITIES
  SALARY
  MAINTENANCE
  OTHER
}
