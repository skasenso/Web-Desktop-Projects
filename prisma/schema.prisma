generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  WORKER
}

model User {
  id            String       @id @default(cuid())
  name          String?
  firstname     String?
  surname       String?
  email         String?      @unique
  emailVerified DateTime?    @map("email_verified")
  phoneNumber   String?      @unique @map("phone_number")
  clerkId       String?      @unique @map("clerk_id")
  image         String?
  accounts      Account[]
  sessions      Session[]
  farms         Farm[]
  role          Role         @default(OWNER)
  memberships   FarmMember[]
  batches       Batch[]
  feedingLogs   FeedingLog[]
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Farm {
  id          Int          @id @default(autoincrement())
  name        String
  location    String?
  capacity    Int
  userId      String       @default("user_placeholder") // Multi-tenancy
  user        User         @relation(fields: [userId], references: [id])
  houses      House[]
  members     FarmMember[]
  invitations Invitation[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@map("farms")
}

model House {
  id                 Int      @id @default(autoincrement())
  farmId             Int
  name               String
  capacity           Int
  currentTemperature Decimal? @db.Decimal(5, 2)
  currentHumidity    Decimal? @db.Decimal(5, 2)
  userId             String   @default("user_placeholder") // Multi-tenancy
  farm               Farm     @relation(fields: [farmId], references: [id])
  batches            Batch[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@map("houses")
}

model Batch {
  id               Int             @id @default(autoincrement())
  houseId          Int
  breedType        String
  initialCount     Int
  currentCount     Int
  arrivalDate      DateTime
  status           String          @default("active")
  userId           String          @default("user_placeholder") // Multi-tenancy
  user             User            @relation(fields: [userId], references: [id])
  house            House           @relation(fields: [houseId], references: [id])
  eggProduction    EggProduction[]
  feedingLogs      FeedingLog[]
  mortalityRecords Mortality[]
  weightRecords    WeightRecord[]
  healthRecords    HealthRecord[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([userId])
  @@map("batches")
}

model Inventory {
  id          Int          @id @default(autoincrement())
  itemName    String
  stockLevel  Decimal      @db.Decimal(10, 2)
  unit        String
  category    String? // feed, medicine, equipment, etc.
  userId      String       @default("user_placeholder") // Multi-tenancy
  feedingLogs FeedingLog[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@map("inventory")
}

model FeedingLog {
  id             Int        @id @default(autoincrement())
  batchId        Int?       @map("batch_id")
  feedTypeId     Int?       @map("feed_type_id")
  amountConsumed Decimal    @map("amount_consumed") @db.Decimal(10, 2)
  logDate        DateTime   @default(now()) @map("log_date")
  userId         String?    @map("user_id") // Supporting RLS
  user           User?      @relation(fields: [userId], references: [id])
  batch          Batch?     @relation(fields: [batchId], references: [id])
  inventory      Inventory? @relation(fields: [feedTypeId], references: [id])

  @@index([userId])
  @@map("daily_feeding_logs")
}

model HealthRecord {
  id          Int      @id @default(autoincrement())
  batchId     Int?     @map("batch_id")
  recordType  String?  @map("record_type") @db.VarChar(50)
  description String?  @db.Text
  recordDate  DateTime @default(now()) @map("record_date") @db.Date
  batch       Batch?   @relation(fields: [batchId], references: [id])

  @@map("health_records")
}

model EggProduction {
  id            Int      @id @default(autoincrement())
  batchId       Int
  eggsCollected Int
  damagedEggs   Int      @default(0)
  crackedEggs   Int      @default(0)
  logDate       DateTime
  userId        String   @default("user_placeholder") // Multi-tenancy
  batch         Batch    @relation(fields: [batchId], references: [id])
  createdAt     DateTime @default(now())

  @@index([userId])
  @@map("egg_production")
}

model Mortality {
  id        Int      @id @default(autoincrement())
  batchId   Int
  count     Int
  reason    String?
  logDate   DateTime
  userId    String   @default("user_placeholder") // Multi-tenancy
  batch     Batch    @relation(fields: [batchId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("mortality")
}

model WeightRecord {
  id            Int      @id @default(autoincrement())
  batchId       Int
  averageWeight Decimal  @db.Decimal(10, 3) // in kg
  logDate       DateTime
  userId        String   @default("user_placeholder")
  batch         Batch    @relation(fields: [batchId], references: [id])
  createdAt     DateTime @default(now())

  @@index([userId])
  @@map("weight_records")
}

model Sale {
  id           Int        @id @default(autoincrement())
  customerName String?
  totalAmount  Decimal    @db.Decimal(10, 2)
  saleDate     DateTime   @default(now())
  status       String     @default("completed") // completed, pending, cancelled
  userId       String     @default("user_placeholder")
  items        SaleItem[]
  createdAt    DateTime   @default(now())

  @@index([userId])
  @@map("sales")
}

model SaleItem {
  id          Int     @id @default(autoincrement())
  saleId      Int
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)
  sale        Sale    @relation(fields: [saleId], references: [id])

  @@map("sale_items")
}

model FarmMember {
  id     Int    @id @default(autoincrement())
  farmId Int
  userId String
  role   Role   @default(WORKER)
  farm   Farm   @relation(fields: [farmId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmId, userId])
  @@map("farm_members")
}

model Invitation {
  id          Int      @id @default(autoincrement())
  email       String?
  phoneNumber String?  @map("phone_number")
  farmId      Int
  role        Role     @default(WORKER)
  status      String   @default("PENDING") // PENDING, ACCEPTED, DECLINED
  farm        Farm     @relation(fields: [farmId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, farmId])
  @@map("invitations")
}
